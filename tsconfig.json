{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "gateway/**/*",
    "channels/**/*",
    "brain/**/*",
    "memory/**/*",
    "skills/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}.json
